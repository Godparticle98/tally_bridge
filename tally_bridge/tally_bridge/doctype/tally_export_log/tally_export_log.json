{
  "doctype": "DocType",
  "name": "Tally Export Log",
  "module": "Tally Bridge",
  "issingle": 0,
  "is_submittable": 0,
  "track_changes": 0,
  "autoname": "TB-.YYYY.-.MM.-.#####",
  "title_field": "export_type",
  "fields": [
    {
      "fieldname": "export_type",
      "fieldtype": "Select",
      "label": "Export Type",
      "options": "Sales Invoice\nPurchase Invoice\nPayment Entry\nJournal Entry\nBank Transaction\nChart of Accounts\nParties\nFull Export",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Pending\nSuccess\nFailed\nPartial",
      "default": "Pending",
      "in_list_view": 1
    },
    {
      "fieldname": "export_format",
      "fieldtype": "Select",
      "label": "Format",
      "options": "Tally XML\nJSON\nExcel",
      "in_list_view": 1
    },
    {
      "fieldname": "from_date",
      "fieldtype": "Date",
      "label": "From Date"
    },
    {
      "fieldname": "to_date",
      "fieldtype": "Date",
      "label": "To Date"
    },
    {
      "fieldname": "records_exported",
      "fieldtype": "Int",
      "label": "Records Exported",
      "read_only": 1
    },
    {
      "fieldname": "records_failed",
      "fieldtype": "Int",
      "label": "Records Failed",
      "read_only": 1
    },
    {
      "fieldname": "exported_at",
      "fieldtype": "Datetime",
      "label": "Exported At",
      "read_only": 1
    },
    {
      "fieldname": "tally_response",
      "fieldtype": "Small Text",
      "label": "Tally Response",
      "read_only": 1
    },
    {
      "fieldname": "error_log",
      "fieldtype": "Code",
      "label": "Error Log",
      "read_only": 1,
      "options": "Text"
    },
    {
      "fieldname": "xml_preview",
      "fieldtype": "Code",
      "label": "XML Preview (first 4000 chars)",
      "read_only": 1,
      "options": "XML"
    },
    {
      "fieldname": "file_attachment",
      "fieldtype": "Attach",
      "label": "Exported File"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "delete": 1
    },
    {
      "role": "Accounts Manager",
      "read": 1,
      "write": 1
    },
    {
      "role": "Accounts User",
      "read": 1
    }
  ]
}
